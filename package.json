{
  "name": "nestjs-mini-ecommerce",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:gateway": "tsx watch apps/api-gateway/src/main.ts",
    "dev:user": "tsx watch apps/user-service/src/main.ts",
    "dev:product": "tsx watch apps/product-service/src/main.ts",
    "dev:order": "tsx watch apps/order-service/src/main.ts",
    "dev:payment": "tsx watch apps/payment-service/src/main.ts",
    "dev": "concurrently -n gateway,user,product,order,payment -c blue,green,magenta,yellow,cyan \"pnpm dev:gateway\" \"pnpm dev:user\" \"pnpm dev:product\" \"pnpm dev:order\" \"pnpm dev:payment\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.16.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ms": "^2.1.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.16.2",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
